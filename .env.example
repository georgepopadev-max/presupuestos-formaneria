# ============================================
# Configuración del Servidor
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# Base de Datos PostgreSQL
# ============================================
DATABASE_URL=postgresql://formaneria:changeme@localhost:5432/presupuestos
POSTGRES_USER=formaneria
POSTGRES_PASSWORD=changeme
POSTGRES_DB=presupuestos

# ============================================
# Cliente (Vite)
# ============================================
VITE_API_URL=http://localhost:3000/api

# ============================================
# Autenticación (para futuro)
# ============================================
JWT_SECRET=tu-secret-aqui-cambiar-en-produccion

# ============================================
# Redis (opcional, para caché)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Producción
# ============================================
# Descomentar y ajustar para deploy:
# VITE_API_URL=https://tu-dominio.com/api
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
